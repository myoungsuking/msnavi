# ===== App =====
NODE_ENV=development

# ===== Server =====
API_HOST=0.0.0.0
API_PORT=4000

# ===== CORS =====
# 콤마(,)로 여러 오리진 지정 가능
# - https://msnavi.msking.co.kr : 운영 도메인 (Cloudflare → 테스트 서버 프록시)
# - 172.22.0.148              : 사내 팀 테스트 서버 IP
# - localhost                 : 로컬 개발 (Expo web/dev-server)
CORS_ORIGINS=https://msnavi.msking.co.kr,http://172.22.0.148:4000,http://172.22.0.148:8081,http://172.22.0.148:19006,http://localhost:4000,http://localhost:8081,http://localhost:19006

# ===== PostgreSQL =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=msnavi
POSTGRES_USER=msnavi
POSTGRES_PASSWORD=msnavi_dev_pw
# SSL 필요 시 true
POSTGRES_SSL=false

# ===== Redis (optional) =====
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL_SEC=300

# ===== Kakao Local API (POI/검색 용도) =====
# https://developers.kakao.com -> 애플리케이션 -> REST API 키
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
KAKAO_NATIVE_APP_KEY=your_kakao_native_app_key_here

# ===== NAVER Cloud Platform Maps =====
# AI·NAVER API > Maps (Mobile Dynamic Map)
# Client ID: X-NCP-APIGW-API-KEY-ID
# Client Secret: X-NCP-APIGW-API-KEY (서버 사이드 전용)
NAVER_MAP_CLIENT_ID=your_naver_client_id
NAVER_MAP_CLIENT_SECRET=your_naver_client_secret

# ===== Security =====
# HSTS max-age (seconds). 0 이면 HSTS 헤더 미적용.
HSTS_MAX_AGE_SEC=15552000

# IP 해시용 솔트. 운영 배포 시 반드시 32+ 랜덤 문자열로 교체.
# (커밋 금지 — .env 만 서버에 두고 .env.example 은 플레이스홀더)
IP_HASH_SALT=change-me-to-random-32-chars

# Rate limit (1분 창 기준 요청 수)
RATE_LIMIT_GLOBAL=120
RATE_LIMIT_EXTERNAL=30
RATE_LIMIT_WRITE=60

# ===== Admin =====
# 관리자 API 키. 32자 이상 랜덤 권장.  빈 값이면 /api/admin/* 전체 비활성.
ADMIN_API_KEY=
# 접근 허용 IP 화이트리스트 (콤마). 비어있으면 IP 제한 없음(키 기반만 사용).
ADMIN_ALLOW_IPS=

# ===== Mobile (apps/mobile) =====
# Expo에서 EXPO_PUBLIC_* 만 클라이언트에 노출됨
EXPO_PUBLIC_API_BASE_URL=https://msnavi.msking.co.kr
EXPO_PUBLIC_KAKAO_JS_KEY=your_kakao_js_key_here
EXPO_PUBLIC_NAVER_MAP_CLIENT_ID=your_naver_client_id
