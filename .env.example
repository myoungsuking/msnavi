# ===== App =====
NODE_ENV=development

# ===== Server =====
API_HOST=0.0.0.0
API_PORT=4000

# ===== CORS =====
# 콤마(,)로 여러 오리진 지정 가능
# 172.22.0.148은 팀 테스트 서버 IP
CORS_ORIGINS=http://172.22.0.148:4000,http://172.22.0.148:8081,http://172.22.0.148:19006,http://localhost:4000,http://localhost:8081,http://localhost:19006

# ===== PostgreSQL =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=msnavi
POSTGRES_USER=msnavi
POSTGRES_PASSWORD=msnavi_dev_pw
# SSL 필요 시 true
POSTGRES_SSL=false

# ===== Redis (optional) =====
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL_SEC=300

# ===== Kakao Local API =====
# https://developers.kakao.com -> 애플리케이션 -> REST API 키
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# ===== Mobile (apps/mobile) =====
# Expo에서 EXPO_PUBLIC_* 만 클라이언트에 노출됨
EXPO_PUBLIC_API_BASE_URL=http://172.22.0.148:4000
EXPO_PUBLIC_KAKAO_JS_KEY=your_kakao_js_key_here
